#!/usr/bin/env bash
set -euo pipefail

PROJECT_ID="maplewood-mgmt"
REGION="us-east5"
REPO="maplewood-backend"
IMAGE="${REGION}-docker.pkg.dev/${PROJECT_ID}/${REPO}/api"
TAG="${1:-latest}"

echo "==> Building image..."
docker build --platform linux/amd64 -t "${IMAGE}:${TAG}" "$(dirname "$0")/../backend/"

echo "==> Pushing to Artifact Registry..."
docker push "${IMAGE}:${TAG}"

echo "==> Updating Cloud Run service..."
gcloud run services update maplewood-backend \
  --image "${IMAGE}:${TAG}" \
  --region "${REGION}" \
  --project "${PROJECT_ID}"

echo "==> Done. Service URL:"
gcloud run services describe maplewood-backend \
  --region "${REGION}" \
  --project "${PROJECT_ID}" \
  --format "value(status.url)"
